# Build stage
FROM node:20-alpine AS builder

WORKDIR /app
COPY techbleat-global-bank-frontend/package*.json ./
RUN npm install --legacy-peer-deps

COPY . .
RUN npm run build

# Production stage
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]